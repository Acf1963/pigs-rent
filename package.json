{
  "name": "pigs-rent-monorepo",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=web\" \"npm run dev --workspace=api\"",
    "web": "npm run dev --workspace=web",
    "api": "npm run dev --workspace=api",
    "build": "npm run build --workspace=web"
  },
  "workspaces": [
    "web",
    "api"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
