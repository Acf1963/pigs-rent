{
  "version": 2,
  "builds": [
    { "src": "api/src/index.ts", "use": "@vercel/node" },
    { "src": "web/package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/src/index.ts" },
    { "src": "/assets/(.*)", "dest": "web/assets/$1", "continue": true },
    { "src": "/(.*)", "dest": "web/$1", "continue": true },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "web/index.html" }
  ]
}