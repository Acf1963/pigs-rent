{
  "version": 2,
  "name": "pigs-rent",
  "builds": [
    {
      "src": "api/src/index.ts",
      "use": "@vercel/node",
      "config": { "helpers": true }
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/src/index.ts",
      "check": true
    },
    {
      "src": "/assets/(.*)",
      "dest": "web/assets/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "web/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "web/index.html"
    }
  ]
}