{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/web/dist/assets/$1"
    },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/web/dist/index.html"
    }
  ]
}
